# ==========================================
# 中继服务配置
# ==========================================
RELAY_URL=ws://your-server-ip:8002
CLIENT_ID=client_001

# ==========================================
# 数据库配置
# ==========================================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=student_talk_db

# ==========================================
# 表结构配置
# ==========================================
# 示例1: 默认结构 (chat_records表)
# TABLE_NAME=chat_records
# STUDENT_ID_FIELD=student_id
# CONTENT_FIELD=content
# CREATED_TIME_FIELD=created_time

# 示例2: talk_record表结构 (根据您的实际表)
TABLE_NAME=talk_record
STUDENT_ID_FIELD=studentNo
CONTENT_FIELD=content
CREATED_TIME_FIELD=talkTime

QUERY_LIMIT=100
