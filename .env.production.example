# ==========================================
# 生产环境配置示例
# 复制此文件为 .env.production，然后修改配置
# ==========================================

# ==========================================
# 数据库配置
# ==========================================
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_strong_database_password
MYSQL_DATABASE=student_talk_db

# ==========================================
# API安全配置（重要！请修改）
# ==========================================
# 生成强API Key的方法：
# - 长度至少32字符
# - 包含大小写字母、数字、符号
# 示例：k9xQ2$pR7!zT4&vL3@wN6
API_KEY=your_strong_production_api_key_please_change_this

# 允许的CORS源（多个用逗号分隔）
# 生产环境建议指定具体域名，不要用 *
CORS_ORIGINS=https://your-domain.com,http://your-domain.com

# 每分钟请求限流
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# 通义千问API Key（如果使用通义千问）
# ==========================================
# 从阿里云控制台获取：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# OpenAI配置（如果使用OpenAI）
# ==========================================
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_BASE_URL=https://api.openai.com/v1
