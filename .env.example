# ==========================================
# 模型配置
# ==========================================
# 支持的模型提供商: tongyi, openai, siliconflow, anthropic
MODEL_PROVIDER=siliconflow
CHAT_MODEL_NAME=deepseek-ai/DeepSeek-V3
EMBEDDING_MODEL_NAME=BAAI/bge-m3

# ==========================================
# 数据库代理服务配置
# ==========================================
PROXY_API_URL=http://localhost:8001
PROXY_API_KEY=test_proxy_key_123

# ==========================================
# API安全配置
# ==========================================
API_KEY=your_secure_api_key_change_this
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==========================================
# 限流配置
# ==========================================
RATE_LIMIT_PER_MINUTE=60

# ==========================================
# 通义千问 API Key (可选)
# ==========================================
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# ==========================================
# 硅基流动 API Key (推荐)
# ==========================================
SILICONFLOW_API_KEY=sk-your-siliconflow-api-key
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# ==========================================
# OpenAI API Key (可选)
# ==========================================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1

# ==========================================
# Anthropic API Key (可选)
# ==========================================
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
